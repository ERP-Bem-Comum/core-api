# Docker Compose secrets (gerados localmente por `pnpm run secrets:setup`)
secrets/*.txt

# Variáveis de ambiente (sempre locais, nunca versionadas)
.env
.env.local
.env.*.local

# Configs locais de outras ferramentas (Gemini CLI, etc.)
.gemini/
