# .env.example — template de variáveis de ambiente do core-api (chaves VAZIAS; nunca commitar segredos).
#
# Catálogo CANÔNICO e completo (frontend + backend, VERIFICADO NO CÓDIGO):
#   ERP-INFRA/docs/env-and-secrets.reference.yaml
#   Runbook de deploy/ops:  ERP-INFRA/docs/runbooks/deploy-and-operations.md
# (o handbook/infrastructure/03-secrets-catalog.md tem partes legadas — prefira o YAML acima.)
#
# Copie para `.env` (gitignored) e preencha. Secrets reais (chaves JWT, *_PASS, *_API_KEY, senhas/URLs de DB)
# vêm do Secrets Manager (homolog/prod) ou Docker secrets — aqui só o SHAPE.
# Convenções:
#   [SECRET]  = nunca em git / imagem / log.
#   sem <MOD>_DRIVER=mysql  → o módulo sobe IN-MEMORY (parece ok, mas NÃO persiste).
#   <vazio>   = use o default citado no comentário.

# ═══ Drivers — selecionam mysql vs in-memory por módulo. Em prod/QA: TODOS = mysql ═══
AUTH_DRIVER=
PARTNERS_DRIVER=
CONTRACTS_DRIVER=
PROGRAMS_DRIVER=
FINANCIAL_DRIVER=

# ═══ Banco de dados (MySQL 8.4) — uma connection string por módulo (ADR-0013/0014) — [SECRET] ═══
# Formato: mysql://core_app:***@host:3306/core?ssl-mode=REQUIRED
AUTH_DATABASE_URL=
PARTNERS_DATABASE_URL=
PARTNERS_READER_URL=            # opcional — réplica de LEITURA (ausente → reusa o writer)
CONTRACTS_DATABASE_URL=
CONTRACTS_READER_URL=           # opcional — réplica de leitura
PROGRAMS_DATABASE_URL=
FINANCIAL_DATABASE_URL=
MIGRATE_DATABASE_URL=           # SÓ no job `migrate` (roda ANTES do http/workers); ausente → exit 78

# ═══ JWT / Auth (ES256) ═══
AUTH_JWT_PRIVATE_KEY=           # [SECRET] chave PRIVADA ES256 (PKCS8 PEM). Obrigatória em PROD
                               #          (ausente → par efêmero no boot; tokens somem a cada restart).
AUTH_JWT_PUBLIC_KEY=            # chave PÚBLICA ES256 (SPKI PEM). Par com a privada (só usa o par do env se AMBAS).
AUTH_LOGIN_RATE_LIMIT_MAX=     # default 5 — limite dedicado de login/refresh por janela
AUTH_LOGIN_RATE_LIMIT_WINDOW= # default "1 minute"
AUTH_RESET_BASE_URL=          # base do link de reset no e-mail. Em prod = URL pública do FRONT.
                              # ex.: https://erp-bem-comum.codebit.biz/reset-password
AUTH_ACTIVATION_BASE_URL=     # base do link de ativação do convite de usuário (#331).
                              # ex.: https://<front>/activate
PARTNERS_SELF_REGISTRATION_BASE_URL= # base do link de autocadastro do colaborador (#331).
# ⚠️ As 3 base URLs acima: URL absoluta http(s), validada no boot; em prod são OBRIGATÓRIAS (ausente/inválida → exit 78).
# ⚠️ E2E ONLY — NUNCA em prod (o seed por env só roda com CORE_API_E2E=1):
# CORE_API_E2E=
# AUTH_SEED_JSON=             # [SECRET] JSON com senhas de seed

# ═══ Object storage / S3 — documentos de contrato + foto de perfil ═══
# Credenciais (XOR): ACCESS+SECRET ambos → estática (MinIO/Magalu); ambos ausentes → IAM Role (prod AWS);
#                    só um → config pela metade (erro).
# ⚠️ S3_REGION + S3_BUCKET são OBRIGATÓRIOS quando CONTRACTS_DRIVER=mysql (LANÇAM no boot).
S3_ENDPOINT=                   # default contracts: https://s3.<region>.amazonaws.com
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=              # [SECRET]
S3_SECRET_ACCESS_KEY=          # [SECRET]
S3_FORCE_PATH_STYLE=           # default false (AWS) / true p/ MinIO/localhost

# Logo de programa — storage PRÓPRIO (sem endpoint+bucket → in-memory)
PROGRAMS_LOGO_S3_ENDPOINT=
PROGRAMS_LOGO_S3_BUCKET=
PROGRAMS_LOGO_S3_REGION=       # default us-east-1
PROGRAMS_LOGO_S3_ACCESS_KEY_ID=        # [SECRET]
PROGRAMS_LOGO_S3_SECRET_ACCESS_KEY=    # [SECRET]
PROGRAMS_LOGO_S3_FORCE_PATH_STYLE=     # default true
# (MAGALU_* existe no código mas NÃO está wired no boot atual — o servidor usa S3_*. Futuro.)

# ═══ E-mail transacional (notifications) ═══
# Provider: smtp | resend | memory. Ausente → smtp se SMTP_* válidos, senão memory (no-op, não envia).
EMAIL_PROVIDER=
# SMTP (provider=smtp) — ex.: smtp.umbler.com:587 STARTTLS (SMTP_SECURE=false) ou :465 (true).
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_REQUIRE_TLS=              # default fail-secure (STARTTLS obrigatório qdo SMTP_SECURE=false); só "false" desativa (dev/Mailpit)
SMTP_USER=
SMTP_PASS=                     # [SECRET]
SMTP_POOL=                     # default true
SMTP_MAX_CONNS=                # default 5
# Resend (provider=resend)
RESEND_API_KEY=                # [SECRET]
# Remetente global + overrides por fluxo (fallback → EMAIL_FROM). Ex.: "Bem Comum <no-reply@dominio>"
EMAIL_FROM=
EMAIL_FROM_RESET=
EMAIL_FROM_INVITE=
EMAIL_FROM_NOTIFICATION=
# [DEPRECADO] aliases legados (só lidos se o EMAIL_FROM_* correspondente estiver ausente):
# AUTH_RESET_FROM=
# AUTH_INVITE_FROM=
# Sandbox: redireciona TODO e-mail para esta caixa. SÓ não-prod (ex.: Mailpit). NUNCA em prod.
EMAIL_SANDBOX_TO=
# Allowlist de domínio do remetente (guarda-corpo #331): CSV de domínios permitidos no From.
# Presente → TODO remetente (EMAIL_FROM* + aliases legados quando usados) deve ter domínio
# na lista (após o @, case-insensitive), senão o boot falha (exit 78). Ausente → sem verificação.
EMAIL_FROM_ALLOWED_DOMAINS=    # ⚠️ RECOMENDADO em prod (ex.: abemcomum.org, mail.abemcomum.org)

# ═══ Borda HTTP / runtime / CORS / proxy (src/shared/http/config.ts) ═══
PORT=                          # default 3000
HOST=                          # default 0.0.0.0
CORS_ORIGINS=                  # CSV de origens; vazio = nega CORS. Só p/ consumidores != BFF (mobile/integrações).
RATE_LIMIT_MAX=                # default 200 (rate-limit global)
RATE_LIMIT_WINDOW=             # default "1 minute"
TRUST_PROXY=                   # default true; em prod preferir o CIDR do proxy (ex.: 10.0.0.0/8) em vez de true
REQUEST_TIMEOUT_MS=            # default 30000 (anti-slowloris)
KEEP_ALIVE_TIMEOUT_MS=         # default 72000
LOG_LEVEL=                     # default warn (pino, com redact de credenciais)
# NODE_ENV: != production EXPÕE /docs e /docs/json (OpenAPI). Em prod = production (a doc NÃO sobe).

# ═══ Outbox / workers (long-running) e jobs (one-shot) ═══
OUTBOX_BATCH_SIZE=             # default 10
OUTBOX_MAX_ATTEMPTS=          # default 5
OUTBOX_POLL_MS=               # default 100
OUTBOX_IDLE_SLEEP_MS=         # default 500
OUTBOX_CONSUMER_ID=           # default outbox-logger-default
OUTBOX_LOG_FILE=              # opcional — path do JSONL de delivery (ausente → sem arquivo)
SWEEP_BATCH_SIZE=             # default 500 — teto do lote do job sweeper (auto-expire de contratos)
