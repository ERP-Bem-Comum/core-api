# .env.example — template de variáveis de ambiente do core-api (chaves VAZIAS; nunca commitar segredos).
# Catálogo canônico e descrições: handbook/infrastructure/03-secrets-catalog.md
# Runbook de e-mail: handbook/infrastructure/08-email-delivery-runbook.md
#
# Copie para `.env` (gitignored) e preencha. Secrets reais (*_PASS, *_API_KEY, senhas de DB) vêm
# do Secrets Manager em homolog/prod — aqui só o shape.

# ─── Banco de dados (MySQL 8.4) — uma connection string por módulo (ADR-0013/0014) ───
CONTRACTS_DATABASE_URL=
AUTH_DATABASE_URL=
PARTNERS_DATABASE_URL=
FINANCIAL_DATABASE_URL=

# ─── E-mail transacional (notifications) — composição por deploy. Detalhes: secrets-catalog §3.6 ───
# Provider: smtp | resend | memory. Ausente → smtp se SMTP_* válidos, senão memory.
EMAIL_PROVIDER=
# SMTP (provider=smtp) — Umbler: smtp.umbler.com:587 STARTTLS (SMTP_SECURE=false) ou :465 (true).
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Pool SMTP (opcional; default true / 5)
SMTP_POOL=
SMTP_MAX_CONNS=
# Resend (provider=resend)
RESEND_API_KEY=
# Remetente global + overrides por fluxo (fallback → EMAIL_FROM). Ex.: "Bem Comum <no-reply@dominio>"
EMAIL_FROM=
EMAIL_FROM_RESET=
EMAIL_FROM_INVITE=
EMAIL_FROM_NOTIFICATION=
# Sandbox: redireciona TODO e-mail para esta caixa. SÓ não-prod (ex.: Mailpit). Nunca em prod.
EMAIL_SANDBOX_TO=

# ─── Borda HTTP (src/server.ts) ───
# PORT=
# RATE_LIMIT_MAX=

# ─── Object storage (S3 / MinIO — ADR-0019) ───
# S3_ENDPOINT=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
