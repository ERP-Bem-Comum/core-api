{
  "name": "core-api",
  "version": "0.1.0",
  "description": "Modular Monolith do ERP Bem Comum. Fase 1: módulo Contratos.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.7.0",
  "imports": {
    "#src/*": "./src/*",
    "#scripts/*": "./scripts/*"
  },
  "scripts": {
    "preinstall": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/only-allow-pnpm.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit": "pnpm audit --prod --audit-level=high",
    "audit:all": "pnpm audit --audit-level=high",
    "test": "node --test --experimental-strip-types --enable-source-maps --no-warnings 'tests/**/*.test.ts'",
    "test:integration": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts contracts",
    "worker:outbox": "node --experimental-strip-types --enable-source-maps --no-warnings src/modules/contracts/worker/run.ts",
    "worker:outbox:partners": "node --experimental-strip-types --enable-source-maps --no-warnings src/modules/partners/worker/run.ts",
    "worker:supplier-projection": "node --experimental-strip-types --enable-source-maps --no-warnings src/workers/supplier-view-projection/run.ts",
    "worker:payable-projection": "node --experimental-strip-types --enable-source-maps --no-warnings src/workers/payable-view-projection/run.ts",
    "worker:contract-count-projection": "node --experimental-strip-types --enable-source-maps --no-warnings src/workers/contract-count-projection/run.ts",
    "worker:email-dispatch": "node --experimental-strip-types --enable-source-maps --no-warnings src/workers/email-dispatch/run.ts",
    "job:contracts:sweep": "node --experimental-strip-types --enable-source-maps --no-warnings src/jobs/contracts/sweeper/run.ts",
    "job:financial:supplier-view-backfill": "node --experimental-strip-types --enable-source-maps --no-warnings src/jobs/financial/supplier-view-backfill/run.ts",
    "job:financial:payable-view-backfill": "node --experimental-strip-types --enable-source-maps --no-warnings src/jobs/financial/payable-view-backfill/run.ts",
    "job:partners:contract-count-backfill": "node --experimental-strip-types --enable-source-maps --no-warnings src/jobs/partners/contract-count-backfill/run.ts",
    "job:migrate": "node --experimental-strip-types --enable-source-maps --no-warnings src/jobs/migrate/run.ts",
    "secrets:setup": "node --experimental-strip-types --enable-source-maps --no-warnings ./scripts/setup/secrets.ts",
    "pipeline:state": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/pipeline/state-cli.ts",
    "pipeline:status": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/pipeline/dashboard-cli.ts",
    "pipeline:metrics": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/pipeline/metrics-cli.ts",
    "test:integration:infra": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts infra",
    "test:integration:notifications": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts notifications",
    "test:integration:storage": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts storage",
    "test:integration:auth": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts auth",
    "test:integration:partners": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts partners",
    "test:integration:programs": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts programs",
    "test:integration:financial": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts financial",
    "test:integration:etl": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts etl",
    "test:integration:etl:orchestrate": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts etl:orchestrate",
    "test:integration:etl:contracts": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts etl:contracts",
    "test:integration:etl:financial": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts etl:financial",
    "etl:check-duplicates": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/etl/diagnostics/check-duplicates.ts",
    "serve": "node --experimental-strip-types --enable-source-maps --no-warnings src/server.ts",
    "dev": "overmind start",
    "test:e2e:auth": "bash scripts/e2e/auth.sh",
    "test:e2e:contracts": "bash scripts/e2e/contracts.sh",
    "test:e2e:collaborators": "bash scripts/e2e/collaborators.sh",
    "test:integration:all": "bash scripts/e2e/bruno-all.sh",
    "test:integration:photo": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts photo",
    "test:integration:logo": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/ci/test-integration.ts logo",
    "db:generate": "drizzle-kit generate --config db/drizzle/contracts.ts",
    "db:generate:auth": "drizzle-kit generate --config db/drizzle/auth.ts",
    "db:generate:partners": "drizzle-kit generate --config db/drizzle/partners.ts",
    "db:generate:programs": "drizzle-kit generate --config db/drizzle/programs.ts",
    "db:generate:financial": "drizzle-kit generate --config db/drizzle/financial.ts",
    "db:generate:notifications": "drizzle-kit generate --config db/drizzle/notifications.ts",
    "db:seed:partners": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/seed/partners.ts",
    "seed:admin": "node --experimental-strip-types --enable-source-maps --no-warnings scripts/seed/admin-user.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "@usebruno/cli": "3.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-zod-openapi": "5.6.1",
    "hash-wasm": "^4.12.0",
    "jose": "^6.2.3",
    "mysql2": "^3.22.3",
    "nodemailer": "^9.0.1",
    "resend": "^6.12.4",
    "zod": "4.4.3",
    "zod-openapi": "5.4.6"
  }
}
