meta {
  name: login senha errada
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v2/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{adminEmail}}",
    "password": "senha-errada-123"
  }
}

tests {
  test("SEC — credencial invalida -> 401", function () {
    expect(res.getStatus()).to.equal(401);
  });
  test("SEC — erro uniforme nao revela se email existe", function () {
    expect(JSON.stringify(res.getBody()).toLowerCase()).to.not.contain("password");
  });
}
