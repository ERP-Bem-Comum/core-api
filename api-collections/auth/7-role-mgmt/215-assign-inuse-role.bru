meta {
  name: US7 atribuir papel em uso ao bare (200)
  type: http
  seq: 215
}

post {
  url: {{baseUrl}}/api/v1/users/{{bareUserId}}/roles
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

body:json {
  {
    "roleId": "{{inUseRoleId}}"
  }
}

tests {
  test("US7 — 200 atribuido", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().assigned).to.equal(true);
  });
}
