meta {
  name: get collaborator after complete registration
  type: http
  seq: 36
}

get {
  url: {{baseUrl}}/api/v1/collaborators/{{collaboratorCreatedId}}
  auth: bearer
}

auth:bearer {
  token: {{operatorToken}}
}

tests {
  test("P2 — GET /collaborators/:id apos complete-registration retorna status Complete", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().status).to.equal("Complete");
  });
}
