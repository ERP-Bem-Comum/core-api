meta {
  name: export suppliers csv
  type: http
  seq: 18
}

get {
  url: {{baseUrl}}/api/v1/suppliers/export
  auth: bearer
}

auth:bearer {
  token: {{operatorToken}}
}

tests {
  test("US-003 — GET /suppliers/export retorna 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("US-003 — content-type eh text/csv", function () {
    const ct = res.getHeader("content-type");
    expect(ct).to.include("text/csv");
  });

  test("US-003 — header content-disposition eh attachment", function () {
    const cd = res.getHeader("content-disposition");
    expect(cd).to.include("attachment");
    expect(cd).to.include(".csv");
  });

  test("US-003 — header x-content-type-options presente", function () {
    expect(res.getHeader("x-content-type-options")).to.equal("nosniff");
  });
}
