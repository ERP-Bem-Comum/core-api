meta {
  name: US7 GET /me (minha conta)
  type: http
  seq: 80
}

get {
  url: {{baseUrl}}/api/v1/me
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

tests {
  test("CA — 200 e email do admin seed", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().email).to.equal("admin.e2e@bemcomum.dev");
  });
  test("SEC — nao expoe passwordHash", function () {
    expect(JSON.stringify(res.getBody())).to.not.contain("passwordHash");
  });
}
