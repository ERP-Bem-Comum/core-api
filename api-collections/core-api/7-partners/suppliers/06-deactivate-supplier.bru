meta {
  name: deactivate supplier
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/suppliers/{{supplierCreatedId}}/deactivate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{partnersOperatorToken}}
}

tests {
  // A borda responde 200 sem corpo (reply.code(200).send()); a transicao e validada pelo status.
  test("CA4 — POST /suppliers/:id/deactivate retorna 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
}
