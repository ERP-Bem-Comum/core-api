# Feature pendente: POST /api/v2/contracts/:id/end não aceita terminatedAt nem reason.
# Schema atual: { kind: 'Expire' | 'Terminate' } apenas.
# Schema esperado: { kind: 'Terminate', terminatedAt: string, reason: string }.
#
# Setup local: 00-setup-create-contract.bru cria e ativa um contrato
# capturando pendingContractId. Os casos DIST-1..6 usam esse id.
#
