meta {
  name: BGP create year invalido (nao numero)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/v2/budget-plans
  body: json
  auth: bearer
}

auth:bearer {
  token: {{budgetPlansOperatorToken}}
}

body:json {
  {
    "year": "abc",
    "programRef": "11111111-1111-4111-8111-111111111111"
  }
}

tests {
  test("BGP — POST /budget-plans com year string retorna 4xx de validacao (nunca 500)", function () {
    const s = res.getStatus();
    expect([400, 422]).to.include(s);
  });
}
