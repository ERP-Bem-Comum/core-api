meta {
  name: US5 deactivate idempotente
  type: http
  seq: 51
}

patch {
  url: {{baseUrl}}/api/v1/users/{{userId}}/deactivate
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

tests {
  test("CA — repetir desativacao -> 200 (idempotente, sem efeito duplicado)", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().active).to.equal(false);
  });
}
