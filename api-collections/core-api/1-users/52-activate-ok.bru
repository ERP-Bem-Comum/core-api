meta {
  name: US5 activate
  type: http
  seq: 52
}

patch {
  url: {{baseUrl}}/api/v1/users/{{userId}}/activate
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

tests {
  test("CA — reativa -> 200 e detalhe active=true", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().active).to.equal(true);
  });
}
