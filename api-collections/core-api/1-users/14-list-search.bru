}

get {
  url: {{baseUrl}}/api/v1/users?search=amanda&pageSize=10
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

tests {
  test("CA — busca retorna 200 com shape paginado", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().items).to.be.an("array");
  });
}
