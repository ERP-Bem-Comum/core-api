meta {
  name: US7 revogar papel em uso (higiene, 200)
  type: http
  seq: 217
}

delete {
  url: {{baseUrl}}/api/v1/users/{{bareUserId}}/roles/{{inUseRoleId}}
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

tests {
  test("US7 — 200 revogado (limpeza)", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().revoked).to.equal(true);
  });
}
