meta {
  name: US4 assign role ao bare
  type: http
  seq: 104
}

post {
  url: {{baseUrl}}/api/v1/users/{{bareUserId}}/roles
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{adminToken}}
}

body:json {
  {
    "roleId": "{{adminRoleId}}"
  }
}

tests {
  test("CA — 200 assigned:true", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().assigned).to.equal(true);
  });
}
