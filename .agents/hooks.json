{
  "hooks": {
    "SessionStart": [
      {
        "name": "session-start-context",
        "type": "command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/session-start-context.sh",
        "timeout": 10000
      }
    ],
    "BeforeModel": [
      {
        "name": "inject-ticket-context",
        "type": "command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/inject-ticket-context.sh",
        "timeout": 10000
      }
    ],
    "BeforeTool": [
      {
        "name": "block-npm",
        "type": "command",
        "matcher": "run_command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/block-npm.sh",
        "timeout": 10000
      },
      {
        "name": "block-cross-project-docker",
        "type": "command",
        "matcher": "run_command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/block-cross-project-docker.sh",
        "timeout": 10000
      }
    ],
    "AfterTool": [
      {
        "name": "prettier-write",
        "type": "command",
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/prettier-write.sh",
        "timeout": 30000
      }
    ],
    "AfterAgent": [
      {
        "name": "subagent-stop-validate",
        "type": "command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/subagent-stop-validate.sh",
        "timeout": 15000
      },
      {
        "name": "stop-typecheck",
        "type": "command",
        "command": "\"$GEMINI_PROJECT_DIR\"/.agents/hooks/stop-typecheck.sh",
        "timeout": 90000
      }
    ]
  }
}
